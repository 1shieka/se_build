// TEST CASE 8 — Feedback Engine: Correct Feedback Generated for Bad Decisions
// ═══════════════════════════════════════════════════════════════════════════════
/**
 * DESCRIPTION:
 *   Validates that the feedback engine identifies and reports bad architectural
 *   decisions. Specifically tests:
 *   1. Waterfall SDLC → "bad" feedback mentioning Waterfall
 *   2. No cache on read-heavy system → "bad" feedback mentioning cache
 *   3. SQL on write-heavy scenario → "bad" feedback mentioning SQL
 *   4. Manual deployment → "bad" feedback mentioning manual deploy
 *
 * EXPECTED BEHAVIOUR:
 *   genFeedback returns at least one "bad" item for each wrong decision;
 *   message content is contextually relevant.
 *
 * TYPE: Unit — Feedback / Insights Engine
 */
describe("TC-08 | Feedback Engine: Flags known bad decisions correctly", () => {
  it("should flag Waterfall SDLC as a bad decision", () => {
    const cfg = {
      scenario:     "instagram",
      sdlc:         "waterfall",
      requirements: [],
      architecture: ["loadBalancer", "cache"],
      db:           "nosql",
      testing:      "medium",
      deployment:   "cicd",
    };
    const res = runSim(cfg, { capacity: 0, latency: 0 }, 0);
    const fb  = genFeedback(cfg, res);
    const bad = fb.filter(f => f.t === "bad");
    expect(bad.length).toBeGreaterThan(0);
    expect(bad.some(f => f.m.toLowerCase().includes("waterfall"))).toBe(true);
  });

  it("should flag missing cache for a read-heavy scenario", () => {
    const cfg = {
      scenario:     "instagram",   // read-heavy
      sdlc:         "agile_s",
      requirements: [],
      architecture: ["loadBalancer"], // NO cache
      db:           "nosql",
      testing:      "medium",
      deployment:   "cicd",
    };
    const res = runSim(cfg, { capacity: 0, latency: 0 }, 0);
    const fb  = genFeedback(cfg, res);
    expect(fb.some(f => f.t === "bad" && f.m.toLowerCase().includes("cache"))).toBe(true);
  });

  it("should flag SQL on write-heavy scenario as a bad decision", () => {
    const cfg = {
      scenario:     "chat",   // write-heavy
      sdlc:         "agile_s",
      requirements: [],
      architecture: ["loadBalancer"],
      db:           "sql",    // bad for write-heavy
      testing:      "medium",
      deployment:   "cicd",
    };
    const res = runSim(cfg, { capacity: 0, latency: 0 }, 0);
    const fb  = genFeedback(cfg, res);
    expect(fb.some(f => f.t === "bad" && f.m.toLowerCase().includes("sql"))).toBe(true);
  });

  it("should flag manual deployment as a bad decision", () => {
    const cfg = {
      scenario:     "instagram",
      sdlc:         "agile_s",
      requirements: [],
      architecture: ["loadBalancer"],
