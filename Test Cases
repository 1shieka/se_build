    {
      label: "best case",
      cfg: { scenario:"instagram", sdlc:"devops", requirements:["performance","reliability"], architecture:["loadBalancer","cache","cdn","apiGateway","msgQueue"], db:"distdb", testing:"chaos", deployment:"canary" },
