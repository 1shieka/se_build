// TEST CASE 1 — Simulation Engine: Worst-Case Configuration Crashes the System
// ═══════════════════════════════════════════════════════════════════════════════
/**
 * DESCRIPTION:
 *   Verifies that the simulation engine correctly sets status to "CRASHED" when
 *   the worst possible configuration is applied:
 *   — No Load Balancer (capacity stays at 500)
 *   — Basic testing (bugRisk +0.20)
 *   — Manual deployment (bugRisk +0.20)
 *   — SQL database on write-heavy scenario (bugRisk +0.25)
 *   — No caching or CDN
 *
 * EXPECTED BEHAVIOUR:
 *   bugRisk exceeds 0.6 threshold OR load exceeds crashThreshold → status = "CRASHED"
 *
 * TYPE: Unit — Simulation Engine (Negative / Failure Path)
 */
describe("TC-01 | Simulation Engine: Worst-case config crashes the system", () => {
  const worstCase = {
    scenario:     "chat",       // write-heavy
    sdlc:         "waterfall",
    requirements: [],
    architecture: [],           // no load balancer, no cache
    db:           "sql",        // bad choice for write-heavy
    testing:      "basic",      // +0.20 bugRisk
    deployment:   "manual",     // +0.20 bugRisk
  };

  it("should return status CRASHED", () => {
    const result = runSim(worstCase, { capacity: 0, latency: 0 }, 0);
    expect(result.status).toBe("CRASHED");
  });

  it("should have bugRisk above crash threshold of 0.6", () => {
    const result = runSim(worstCase, { capacity: 0, latency: 0 }, 0);
    const isCrashedByBug  = result.bugRisk > 0.6;
    const isCrashedByLoad = result.load    > result.crashThreshold;
    expect(isCrashedByBug || isCrashedByLoad).toBe(true);
  });

  it("should have an error rate above 40%", () => {
    const result = runSim(worstCase, { capacity: 0, latency: 0 }, 0);
    expect(result.errRate).toBeGreaterThan(40);
  });
});


