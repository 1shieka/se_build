// TEST CASE 3 — Architecture: Load Balancer Increases Capacity by 1.5×
// ═══════════════════════════════════════════════════════════════════════════════
/**
 * DESCRIPTION:
 *   Confirms the Load Balancer multiplier (×1.5) is applied correctly by
 *   comparing the resulting capacity with and without it, using an identical
 *   baseline configuration.
 *
 * EXPECTED BEHAVIOUR:
 *   capacity(with LB) ≈ capacity(without LB) × 1.5
 *
 * TYPE: Unit — Architecture Component Logic
 */
describe("TC-03 | Architecture: Load Balancer applies 1.5× capacity multiplier", () => {
  const base = {
    scenario:     "instagram",
    sdlc:         "agile_s",
    requirements: [],
    architecture: [],
    db:           "nosql",
    testing:      "medium",
    deployment:   "cicd",
  };

  it("should increase capacity by exactly 1.5× when Load Balancer is added", () => {
    const withoutLB = runSim(base, { capacity: 0, latency: 0 }, 0);
    const withLB    = runSim(
      { ...base, architecture: ["loadBalancer"] },
      { capacity: 0, latency: 0 },
      0
    );
    expect(withLB.capacity).toBeCloseTo(withoutLB.capacity * 1.5, 1);
  });

  it("should result in lower load ratio when Load Balancer is present", () => {
    const withoutLB = runSim(base, { capacity: 0, latency: 0 }, 0);
    const withLB    = runSim(
      { ...base, architecture: ["loadBalancer"] },
      { capacity: 0, latency: 0 },
