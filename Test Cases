// TEST CASE 5 — Cache Hit Rate: Correct Calculation for Read-Heavy Scenario
// ═══════════════════════════════════════════════════════════════════════════════
/**
 * DESCRIPTION:
 *   Validates the cache hit rate accumulation formula:
 *     base = 60%
 *     +15%  if CDN is present
 *     +10%  if scenario is read-heavy
 *     cap at 95%
 *
 *   Test matrix covers: cache only, cache + CDN, and cache + CDN + read-heavy.
 *
 * EXPECTED BEHAVIOUR:
 *   cacheHit = 0 if no cache component
 *   cacheHit = 60 for non-read-heavy + cache only
 *   cacheHit = 85 for read-heavy + cache + CDN (60 + 15 + 10)
 *   cacheHit = 0 when cache component is absent
 *
 * TYPE: Unit — Cache Hit Rate Logic
 */
describe("TC-05 | Cache: Hit rate calculated correctly per configuration", () => {
  const base = {
    scenario:     "instagram", // read-heavy
    sdlc:         "agile_s",
    requirements: [],
    architecture: [],
    db:           "nosql",
    testing:      "medium",
    deployment:   "cicd",
  };

  it("should return 0% cache hit rate when no cache component is selected", () => {
    const result = runSim(base, { capacity: 0, latency: 0 }, 0);
    expect(result.cacheHit).toBe(0);
  });

  it("should return 70% cache hit rate for read-heavy scenario with cache only", () => {
    // 60 base + 10 read-heavy = 70
    const result = runSim(
      { ...base, architecture: ["cache"] },
      { capacity: 0, latency: 0 },
      0
    );
    expect(result.cacheHit).toBe(70);
  });

  it("should return 85% cache hit rate for read-heavy scenario with cache + CDN", () => {
