/**
 * DESCRIPTION:
 *   Validates that the scoring formula never produces a value outside the [0, 100]
 *   range regardless of configuration. Tests the worst possible and best possible
 *   scenarios, and an extreme edge case (cost-optimised with no infrastructure).
 *
 * EXPECTED BEHAVIOUR:
 *   0 ≤ score ≤ 100 for all configurations
 *
 * TYPE: Unit — Scoring Engine / Boundary Conditions
 */
describe("TC-09 | Score Boundaries: score is always clamped between 0 and 100", () => {
  const configs = [
    {
      label: "worst case",
      cfg: { scenario:"chat", sdlc:"waterfall", requirements:[], architecture:[], db:"sql", testing:"basic", deployment:"manual" },
